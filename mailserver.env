# ─────────────────────────────────────────────────────────────
# GSV Office — docker-mailserver Settings
# ─────────────────────────────────────────────────────────────

# Network and relay settings
OVERTAKE_IP=172.20.0.0/16

# Security & Spam filters (Disabled by default for low memory consumption)
ENABLE_SPAMASSASSIN=0
ENABLE_CLAMAV=0
ENABLE_FAIL2BAN=0
ENABLE_POSTGREY=0

# Runtime config
ONE_DIR=1
DMS_DEBUG=0
ENABLE_SRS=0
ENABLE_SPF=1
ENABLE_DKIM=1
ENABLE_DMARC=1
