# ═══════════════════════════════════════════════════════════════
#  GSV Office — Environment Configuration
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── Application ───────────────────────────────────────────────
APP_NAME="GSV Office"
APP_VERSION=1.0.14
NODE_ENV=production
PORT=3000

# Server access URL (your local IP or hostname)
APP_URL=http://192.168.1.100
APP_DOMAIN=192.168.1.100

# ─── Ports ─────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
DB_EXTERNAL_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── JWT Authentication ─────────────────────────────────────────
JWT_ACCESS_SECRET=change_this_to_a_very_long_random_secret_string_at_least_64_chars
JWT_REFRESH_SECRET=change_this_to_another_very_long_random_secret_string_at_least_64_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Database (PostgreSQL) ──────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=gsv_office
DB_USER=gsv_admin
DB_PASSWORD=change_this_strong_password_2024
DB_SSL=false
DB_SYNC=false
DB_LOGGING=false

# ─── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# ─── MinIO Object Storage ───────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=gsv_minio_admin
MINIO_ROOT_PASSWORD=change_this_minio_password_2024
MINIO_BUCKET_FILES=gsv-files
MINIO_BUCKET_AVATARS=gsv-avatars
MINIO_BUCKET_CHAT=gsv-chat

# ─── SMB Storage (TrueNAS) ─────────────────────────────────────
SMB_ENABLED=false
SMB_HOST=192.168.1.1
SMB_SHARE=gsv_storage
SMB_USERNAME=gsv_smb_user
SMB_PASSWORD=smb_password
SMB_DOMAIN=WORKGROUP
SMB_MOUNT_PATH=/mnt/smb

# Upload storage path (inside container)
UPLOAD_PATH=/app/uploads
MAX_FILE_SIZE_MB=5000

# ─── Mail Server ────────────────────────────────────────────────
MAIL_DOMAIN=gsv.local
MAIL_HOST=mailserver
MAIL_PORT=587
MAIL_USER=admin@gsv.local
MAIL_PASSWORD=mail_password
MAIL_FROM="GSV Office <noreply@gsv.local>"
MAIL_SECURE=false

# IMAP (for receiving email)
IMAP_HOST=mailserver
IMAP_PORT=143
IMAP_SECURE=false

# ─── WebRTC / TURN Server ──────────────────────────────────────
TURN_SERVER=192.168.1.100
TURN_PORT=3478
TURN_USERNAME=gsv_turn
TURN_PASSWORD=turn_password_change_this

# ─── Security ───────────────────────────────────────────────────
BCRYPT_ROUNDS=12
SESSION_SECRET=change_this_session_secret_very_long_string
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=300

# ─── Default Admin Account ──────────────────────────────────────
ADMIN_EMAIL=admin@gsv.local
ADMIN_PASSWORD=Admin@GSV2024
ADMIN_NAME="System Administrator"

# ─── Company Branding ───────────────────────────────────────────
COMPANY_NAME="GSV Office"
COMPANY_LOGO_URL=/assets/logo.png
COMPANY_PRIMARY_COLOR=#6366f1
COMPANY_SECONDARY_COLOR=#8b5cf6

# ─── GST / Billing ─────────────────────────────────────────────
DEFAULT_CURRENCY=INR
DEFAULT_CURRENCY_SYMBOL=₹
DEFAULT_TAX_LABEL=GST
DEFAULT_TIMEZONE=Asia/Kolkata

# ─── Logging ────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_TO_FILE=true
LOG_PATH=/app/logs

# ─── Plugin System ──────────────────────────────────────────────
PLUGINS_PATH=/app/plugins
PLUGINS_ENABLED=true
